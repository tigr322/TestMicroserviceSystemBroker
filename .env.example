APP_NAME="Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8088
APP_TIMEZONE=UTC
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notifications
DB_USERNAME=notifications
DB_PASSWORD=secret

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# Cache / Session / Queue default
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=rabbitmq

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE_NAME=notifications
RABBITMQ_EXCHANGE_TYPE=direct

# Idempotency TTL (seconds) — 24 hours
IDEMPOTENCY_TTL=86400

# Horizon
HORIZON_PREFIX=horizon:

# L5-Swagger
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_DOC_EXPANSION=list
L5_SWAGGER_CONST_HOST=http://localhost:8088

# Nginx
NGINX_PORT=8088

# RabbitMQ management UI
RABBITMQ_MANAGEMENT_PORT=15672
